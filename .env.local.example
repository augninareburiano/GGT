# ── FareHarbor booking embed ──
# Company shortname from your dashboard URL: fareharbor.com/<shortname>/dashboard/
# Leave blank and every booking CTA falls back to the on-page tour builder.
NEXT_PUBLIC_FAREHARBOR_SHORTNAME=

# Item ID overrides — all default to this account's catalogue in
# lib/fareharbor.ts, so you only need these if the items are ever renumbered.
#   FLAGSHIP = Hunter Valley (65971) · header, hero and footer CTAs
#   PRIVATE  = Private Tours (65977) · every custom builder itinerary
#   GIFT     = Gift Card     (243773) · footer gift link
# NEXT_PUBLIC_FAREHARBOR_FLAGSHIP_ITEM_ID=
# NEXT_PUBLIC_FAREHARBOR_PRIVATE_ITEM_ID=
# NEXT_PUBLIC_FAREHARBOR_GIFT_ITEM_ID=

# Booking flow ID. Leave blank to use the account's default flow.
# NEXT_PUBLIC_FAREHARBOR_FLOW=4437

# ── Firebase client SDK (browser; used for Admin Auth login) ──
# From Firebase Console → Project settings → Your apps → Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server only) ──
# The FULL service-account JSON on a single line. From Firebase Console →
# Project settings → Service accounts → Generate new private key.
# Example: {"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n", ...}
FIREBASE_SERVICE_ACCOUNT=

# ── Admin allowlist ──
# Comma-separated emails allowed into /admin and admin API routes.
ADMIN_EMAILS=you@example.com

# ── Email notifications (Resend) — optional ──
# If unset, enquiries are still saved; only the email is skipped. A failing or
# misconfigured Resend never costs you an enquiry — but check the server logs,
# because a rejected send is reported there and nowhere else.
#
# The domain in ENQUIRY_FROM_EMAIL must EXACTLY match a domain you have
# verified in Resend (Domains → Add Domain, then add the MX/SPF/DKIM records).
# Verifying `example.com` and sending from `mail.example.com` is rejected with
# a 403 on every send. Note the sending region is fixed when the domain is
# created and cannot be changed afterwards.
#
# Before the domain verifies you can send from `onboarding@resend.dev`, but it
# only delivers to the address that owns the Resend account.
RESEND_API_KEY=
ENQUIRY_TO_EMAIL=bookings@gourmetgetaway.example
ENQUIRY_FROM_EMAIL=Gourmet Getaway <noreply@gourmetgetaway.example>