# ── Firebase client SDK (browser; used for Admin Auth login) ──
# From Firebase Console → Project settings → Your apps → Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server only) ──
# The FULL service-account JSON on a single line. From Firebase Console →
# Project settings → Service accounts → Generate new private key.
# Example: {"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n", ...}
FIREBASE_SERVICE_ACCOUNT=

# ── Admin allowlist ──
# Comma-separated emails allowed into /admin and admin API routes.
ADMIN_EMAILS=you@example.com

# ── Email notifications (Resend) — optional ──
# If unset, enquiries are still saved; only the email is skipped.
RESEND_API_KEY=
ENQUIRY_TO_EMAIL=bookings@gourmetgetaway.example
ENQUIRY_FROM_EMAIL=Gourmet Getaway <noreply@gourmetgetaway.example>

# ── Ad conversion tracking (public; browser) — optional ──
# All dormant until set: no scripts load and no events fire when these are blank,
# so local/dev traffic never pollutes your ad stats.
#
# Google Ads: from Google Ads → Goals → Conversions → your action → tag setup.
#   ID looks like "AW-123456789"; the label is the string after the "/".
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_ENQUIRY_LABEL=
#
# Meta (Facebook) Pixel: from Meta Events Manager → your pixel → Settings.
#   ID is the numeric pixel ID, e.g. "1234567890".
NEXT_PUBLIC_META_PIXEL_ID=