# ── Firebase client SDK (browser; used for Admin Auth login) ──
# From Firebase Console → Project settings → Your apps → Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server only) ──
# The FULL service-account JSON on a single line. From Firebase Console →
# Project settings → Service accounts → Generate new private key.
# Example: {"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n", ...}
FIREBASE_SERVICE_ACCOUNT=

# ── Admin allowlist ──
# Comma-separated emails allowed into /admin and admin API routes.
ADMIN_EMAILS=you@example.com

# ── Email notifications (Resend) — optional ──
# If unset, enquiries are still saved; only the email is skipped.
# The FROM domain must be verified in Resend.
RESEND_API_KEY=
ENQUIRY_TO_EMAIL=info@gourmetgetaway.com.au
ENQUIRY_FROM_EMAIL=Gourmet Getaway <info@gourmetgetaway.com.au>

# ── Error alerts (Resend) — optional ──
# Where server error alerts are emailed. Defaults to ENQUIRY_TO_EMAIL if unset.
ALERT_TO_EMAIL=info@gourmetgetaway.com.au

# ── Analytics (Plausible) — optional ──
# Set to the site's domain (as registered in Plausible) to enable analytics.
# Leave blank to disable — no script loads and no data is collected.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Only override if self-hosting Plausible or using a custom/proxy script URL.
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js