# ── Firebase client SDK (browser; used for Admin Auth login) ──
# From Firebase Console → Project settings → Your apps → Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server only) ──
# The FULL service-account JSON on a single line. From Firebase Console →
# Project settings → Service accounts → Generate new private key.
# Example: {"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n", ...}
FIREBASE_SERVICE_ACCOUNT=

# ── Admin allowlist ──
# Comma-separated emails allowed into /admin and admin API routes.
ADMIN_EMAILS=you@example.com

# ── Email notifications (Resend) — optional ──
# If unset, enquiries are still saved; only the emails are skipped.
# ENQUIRY_TO_EMAIL is the business/Jimmy inbox (enquiry + confirmation notices).
RESEND_API_KEY=
ENQUIRY_TO_EMAIL=bookings@gourmetgetaway.example
ENQUIRY_FROM_EMAIL=Gourmet Getaway <noreply@gourmetgetaway.example>

# ── Booking reminders & review requests ──
# CRON_SECRET protects /api/cron/dispatch, the daily sweep that sends day-before
# reminders and after-tour review requests. The Netlify scheduled function
# (netlify/functions/daily-dispatch.mts) calls the route with this same secret.
# Use a long random string; the sweep is disabled until it's set.
CRON_SECRET=

# Where the after-tour review email sends guests (e.g. a Google review link).
# Falls back to NEXT_PUBLIC_SITE_URL if unset.
REVIEW_URL=

# Public site origin, used for links and the calendar invite. On Netlify the
# built-in URL env var is used as a fallback for the cron trigger.
NEXT_PUBLIC_SITE_URL=https://gourmetgetaway.example