# ── Firebase client SDK (browser; used for Admin Auth login) ──
# From Firebase Console → Project settings → Your apps → Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server only) ──
# The FULL service-account JSON on a single line. From Firebase Console →
# Project settings → Service accounts → Generate new private key.
# Example: {"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n", ...}
FIREBASE_SERVICE_ACCOUNT=

# ── Admin allowlist ──
# Comma-separated emails allowed into /admin and admin API routes.
ADMIN_EMAILS=you@example.com

# ── Email notifications (Resend) — optional ──
# If unset, enquiries are still saved; only the email is skipped.
RESEND_API_KEY=
ENQUIRY_TO_EMAIL=bookings@gourmetgetaway.example
ENQUIRY_FROM_EMAIL=Gourmet Getaway <noreply@gourmetgetaway.example>

# ── Stripe (payments) ──
# Dashboard → Developers → API keys. Use test keys (sk_test_… / pk_test_…) in dev.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (whsec_…). From `stripe listen` locally, or the
# Dashboard → Developers → Webhooks endpoint. Required to accept webhooks.
STRIPE_WEBHOOK_SECRET=

# ── Business identity (for GST tax invoices) ──
# Australian tax invoices must show the seller's identity and ABN.
BUSINESS_LEGAL_NAME=Gourmet Getaway Tours Pty Ltd
BUSINESS_ABN=
BUSINESS_ADDRESS=Sydney, NSW, Australia

# ── Payment policy ──
# Deposit taken up front, as a percentage of the total (balance due before the tour).
DEPOSIT_PERCENT=20
# Comma-separated ISO codes offered at checkout. AUD is always included.
SUPPORTED_CURRENCIES=AUD,USD,EUR,GBP,NZD,CAD,SGD,JPY
# Refund tiers (Phase 2): daysBefore:refundPercent, highest days first.
# e.g. full refund 30+ days out, 50% within 7–30 days, nothing inside 7 days.
REFUND_TIERS=30:100,7:50,0:0

# ── FX rates (Wise-style converted display + local-currency charging) ──
# Mid-market rate provider. Default uses the free open.er-api.com (base=AUD).
FX_API_URL=https://open.er-api.com/v6/latest/AUD