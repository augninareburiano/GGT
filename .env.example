# ─────────────────────────────────────────────────────────────────────────────
# Gourmet Getaway Tours — environment variables
#
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# All secrets are read from the environment only (see src/lib/env.ts).
# Everything here is TEST MODE only for now.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database: Postgres via Supabase ──────────────────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string (URI).
# Use the connection-pooler URI (port 6543) for serverless/Netlify Functions.
# Make sure `sslmode=require` is present.
# Example: postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# ── Supabase API keys ────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API.
# The project URL and the public anon key are safe for the browser.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# The service-role key bypasses Row Level Security. SERVER ONLY — never expose
# it to the client. Currently unused (we talk to Postgres directly via
# DATABASE_URL) but kept here for future Supabase-client/storage use.
SUPABASE_SERVICE_ROLE_KEY=

# ── Email: Resend (test mode) ────────────────────────────────────────────────
# Resend Dashboard → API Keys. https://resend.com
RESEND_API_KEY=
# Where new enquiry notifications are sent (the business owner).
OWNER_EMAIL=
# Verified "from" address for outbound mail. In test mode you can use
# "onboarding@resend.dev" until your own domain is verified.
EMAIL_FROM="Gourmet Getaway Tours <onboarding@resend.dev>"

# ── Payments: Stripe (TEST MODE) ─────────────────────────────────────────────
# Stripe Dashboard (Test mode) → Developers → API keys.
# Secret key — SERVER ONLY. Test keys start with sk_test_...
STRIPE_SECRET_KEY=
# Webhook signing secret for POST /api/stripe-webhook.
# From `stripe listen` (local) or Dashboard → Developers → Webhooks. Starts whsec_...
STRIPE_WEBHOOK_SECRET=
# Publishable key — safe for the browser. Test keys start with pk_test_...
PUBLIC_STRIPE_KEY=

# ── App ──────────────────────────────────────────────────────────────────────
# Public base URL of the site, used to build Stripe success/cancel return URLs.
# Local dev: http://localhost:4321
PUBLIC_SITE_URL=http://localhost:4321
